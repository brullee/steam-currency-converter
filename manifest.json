{
  "manifest_version": 3,
  "name": "Steam Currency Converter",
  "version": "1.0",
  "description": "Converts Steam prices",

  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Steam Currency Converter"
  },

  "browser_specific_settings": {
    "gecko": {
      "id": "steam-currency-converter@local"
    }
  },

  "permissions": ["storage", "tabs"],
  "background": { "service_worker": "background/background.js", "scripts": ["background/background.js"] },
  
  "host_permissions": [
    "*://store.steampowered.com/*",
    "*://steamcommunity.com/*",
    "*://checkout.steampowered.com/*",
    "*://api.exchangerate-api.com/*"
  ],

  "content_scripts": [
    {
      "matches": [
        "*://store.steampowered.com/*",
        "*://steamcommunity.com/*",
        "*://checkout.steampowered.com/*"
      ],
      "js": ["shared/currencies.js", "shared/api.js", "content/content.js"],
      "css": ["content/style.css"],
      "run_at": "document_end",
      "all_frames": true
    }
  ]
}