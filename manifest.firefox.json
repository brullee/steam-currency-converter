{
  "manifest_version": 3,
  "name": "Steam Currency Converter",
  "version": "1.1",
  "description": "Convert Steam prices to your chosen currency in real time. Supports 48 currencies with customizable symbols, number formatting, and market dialog support.",

"icons": {
    "16": "icons/steam-cc_16x16.png",
    "32": "icons/steam-cc_32x32.png",
    "48": "icons/steam-cc_48x48.png",
    "64": "icons/steam-cc_64x64.png",
    "128": "icons/steam-cc_128x128.png"
  },

  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Steam Currency Converter"
  },

  "browser_specific_settings": {
    "gecko": {
      "id": "steam-currency-converter@local",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },

  "permissions": ["storage", "tabs"],
  "background": { "scripts": ["background/background.js"] },
  
  "host_permissions": [
    "*://store.steampowered.com/*",
    "*://steamcommunity.com/*",
    "*://checkout.steampowered.com/*",
    "*://api.exchangerate-api.com/*"
  ],

  "content_scripts": [
    {
      "matches": [
        "*://store.steampowered.com/*",
        "*://steamcommunity.com/*",
        "*://checkout.steampowered.com/*"
      ],
      "js": ["shared/currencies.js", "shared/api.js", "content/content.js"],
      "css": ["content/style.css"],
      "run_at": "document_end",
      "all_frames": true
    }
  ]
}